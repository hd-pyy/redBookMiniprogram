.container {
    padding: 40rpx;
  }
  .title {
    font-size: 36rpx;
    font-weight: bold;
    margin-bottom: 40rpx;
  }
  .input {
    border: 1px solid #ddd;
    border-radius: 8rpx;
    padding: 20rpx;
    font-size: 28rpx;
    margin-bottom: 30rpx;
  }
  .btn {
    background-color: #ff2442;
    color: #fff;
    border: none;
    border-radius: 8rpx;
    padding: 20rpx 0;
    font-size: 30rpx;
    width: 100%;
    margin-bottom: 30rpx;
    transition: background 0.5s;
  }
  .btn:active {
    background-color: #d81e3a;
    opacity: 0.85;
  }
  .result {
    font-size: 28rpx;
    color: #333;
    margin-top: 20rpx;
    word-break: break-all;
  }
  